---
const year = new Date().getFullYear();
---

<footer class="border-t border-gray-200 bg-gray-50">
  <div class="mx-auto grid max-w-6xl gap-8 px-4 py-10 sm:grid-cols-2 md:grid-cols-4">
    <div>
      <div class="flex items-center gap-2 text-lg font-bold text-brand">
        <span class="grid h-7 w-7 place-items-center rounded-lg bg-brand text-white text-sm">AI</span>
        Sekolah AI
      </div>
      <p class="mt-3 text-sm text-gray-600">
        Ekosistem belajar kecerdasan buatan untuk semua kalangan.
      </p>
    </div>
    <div>
      <h3 class="text-sm font-semibold text-gray-900">Navigasi</h3>
      <ul class="mt-3 space-y-2 text-sm text-gray-600">
        <li><a href="/" class="hover:text-brand">Home</a></li>
        <li><a href="/tentang" class="hover:text-brand">Tentang</a></li>
        <li><a href="/blog" class="hover:text-brand">Blog</a></li>
      </ul>
    </div>
    <div>
      <h3 class="text-sm font-semibold text-gray-900">Lainnya</h3>
      <ul class="mt-3 space-y-2 text-sm text-gray-600">
        <li><a href="/produk" class="hover:text-brand">Produk</a></li>
        <li><a href="/komunitas" class="hover:text-brand">Komunitas</a></li>
        <li><a href="/kontak" class="hover:text-brand">Kontak</a></li>
      </ul>
    </div>
    <div>
      <h3 class="text-sm font-semibold text-gray-900">Kontak</h3>
      <ul class="mt-3 space-y-2 text-sm text-gray-600">
        <li>halo@sekolah-ai.my.id</li>
        <li>Indonesia</li>
      </ul>
    </div>
  </div>
  <div class="border-t border-gray-200 py-4 text-center text-sm text-gray-500">
    &copy; {year} Sekolah AI. Semua hak dilindungi.
  </div>
</footer>
