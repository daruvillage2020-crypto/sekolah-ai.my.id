---
const links = [
  { href: "/", label: "Home" },
  { href: "/tentang", label: "Tentang" },
  { href: "/blog", label: "Blog" },
  { href: "/produk", label: "Produk" },
  { href: "/komunitas", label: "Komunitas" },
  { href: "/kontak", label: "Kontak" },
];

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path.startsWith(href);
---

<header class="sticky top-0 z-50 bg-white/90 backdrop-blur border-b border-gray-200">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4">
    <a href="/" class="flex items-center gap-2 text-xl font-bold text-brand">
      <span class="grid h-8 w-8 place-items-center rounded-lg bg-brand text-white">AI</span>
      Sekolah AI
    </a>

    <ul class="hidden items-center gap-6 md:flex">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              "text-sm font-medium transition-colors hover:text-brand",
              isActive(link.href) ? "text-brand" : "text-gray-600",
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <button
      id="menu-toggle"
      class="md:hidden text-gray-700"
      aria-label="Buka menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <div id="mobile-menu" class="hidden border-t border-gray-200 md:hidden">
    <ul class="flex flex-col px-4 py-2">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              "block py-2 text-sm font-medium",
              isActive(link.href) ? "text-brand" : "text-gray-700",
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => menu?.classList.toggle("hidden"));
</script>
