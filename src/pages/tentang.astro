---
import Layout from "../layouts/Layout.astro";

const values = [
  { title: "Misi", desc: "Membuat pendidikan AI dapat diakses semua orang di Indonesia." },
  { title: "Visi", desc: "Menjadi ekosistem belajar AI terpercaya dan inklusif." },
  { title: "Nilai", desc: "Kolaborasi, keterbukaan, dan pembelajaran berkelanjutan." },
];
---

<Layout title="Tentang — Sekolah AI">
  <section class="mx-auto max-w-4xl px-4 py-16">
    <h1 class="text-4xl font-bold text-gray-900">Tentang Sekolah AI</h1>
    <p class="mt-4 text-lg text-gray-600">
      Sekolah AI adalah ekosistem belajar kecerdasan buatan yang lahir dari
      keinginan untuk membuka akses pengetahuan AI bagi siapa saja. Kami percaya
      bahwa setiap orang berhak memahami dan memanfaatkan teknologi AI.
    </p>

    <div class="mt-12 grid gap-6 md:grid-cols-3">
      {values.map((v) => (
        <div class="rounded-xl border border-gray-200 p-6">
          <h2 class="text-lg font-semibold text-brand">{v.title}</h2>
          <p class="mt-2 text-sm text-gray-600">{v.desc}</p>
        </div>
      ))}
    </div>

    <div class="mt-12 rounded-xl bg-blue-50 p-8">
      <h2 class="text-2xl font-bold text-gray-900">Cerita Kami</h2>
      <p class="mt-3 text-gray-600">
        Dimulai dari komunitas kecil yang berbagi materi AI secara gratis,
        Sekolah AI kini berkembang menjadi platform lengkap dengan kurikulum,
        produk pembelajaran, dan komunitas aktif yang saling mendukung.
      </p>
    </div>
  </section>
</Layout>
