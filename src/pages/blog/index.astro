---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const fmt = (d: Date) =>
  d.toLocaleDateString("id-ID", { day: "numeric", month: "long", year: "numeric" });
---

<Layout title="Blog — Sekolah AI">
  <section class="mx-auto max-w-5xl px-4 py-16">
    <h1 class="text-4xl font-bold text-gray-900">Blog</h1>
    <p class="mt-3 text-lg text-gray-600">
      Artikel, tutorial, dan wawasan seputar kecerdasan buatan.
    </p>

    <div class="mt-10 grid gap-6 md:grid-cols-2">
      {posts.map((post) => (
        <a
          href={`/blog/${post.id}`}
          class="block rounded-xl border border-gray-200 p-6 transition hover:shadow-md"
        >
          <time class="text-sm text-brand">{fmt(post.data.date)}</time>
          <h2 class="mt-2 text-xl font-semibold text-gray-900">{post.data.title}</h2>
          <p class="mt-2 text-sm text-gray-600">{post.data.description}</p>
          <span class="mt-4 inline-block text-sm font-medium text-brand">Baca selengkapnya →</span>
        </a>
      ))}
    </div>
  </section>
</Layout>
