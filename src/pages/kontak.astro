---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Kontak — Sekolah AI">
  <section class="mx-auto max-w-5xl px-4 py-16">
    <div class="text-center">
      <h1 class="text-4xl font-bold text-gray-900">Hubungi Kami</h1>
      <p class="mx-auto mt-3 max-w-2xl text-lg text-gray-600">
        Punya pertanyaan atau ingin bekerja sama? Kirim pesan kepada kami.
      </p>
    </div>

    <div class="mt-12 grid gap-10 md:grid-cols-2">
      <div class="space-y-6">
        <div>
          <h2 class="text-sm font-semibold text-gray-900">Email</h2>
          <p class="mt-1 text-gray-600">halo@sekolah-ai.my.id</p>
        </div>
        <div>
          <h2 class="text-sm font-semibold text-gray-900">Lokasi</h2>
          <p class="mt-1 text-gray-600">Indonesia (Remote)</p>
        </div>
        <div>
          <h2 class="text-sm font-semibold text-gray-900">Jam Operasional</h2>
          <p class="mt-1 text-gray-600">Senin - Jumat, 09.00 - 17.00 WIB</p>
        </div>
      </div>

      <form
        name="kontak"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="space-y-4"
      >
        <input type="hidden" name="form-name" value="kontak" />
        <p class="hidden">
          <label>Jangan isi ini: <input name="bot-field" /></label>
        </p>
        <div>
          <label for="nama" class="block text-sm font-medium text-gray-700">Nama</label>
          <input
            id="nama"
            name="nama"
            type="text"
            required
            class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2 focus:border-brand focus:outline-none focus:ring-1 focus:ring-brand"
          />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-gray-700">Email</label>
          <input
            id="email"
            name="email"
            type="email"
            required
            class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2 focus:border-brand focus:outline-none focus:ring-1 focus:ring-brand"
          />
        </div>
        <div>
          <label for="pesan" class="block text-sm font-medium text-gray-700">Pesan</label>
          <textarea
            id="pesan"
            name="pesan"
            rows="5"
            required
            class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2 focus:border-brand focus:outline-none focus:ring-1 focus:ring-brand"
          ></textarea>
        </div>
        <button
          type="submit"
          class="w-full rounded-lg bg-brand px-4 py-2.5 font-medium text-white transition hover:bg-brand-dark"
        >
          Kirim Pesan
        </button>
      </form>
    </div>
  </section>
</Layout>
